{
  "name": "haruspex-chatgpt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/src/index.ts",
    "build": "npm run build:web && npm run build:server",
    "build:web": "esbuild web/src/component.tsx --bundle --format=esm --outfile=web/dist/component.js",
    "build:server": "tsc -p tsconfig.json",
    "start": "node dist/server/src/index.js",
    "smoke:test": "tsx server/src/smoke-test.ts",
    "smoke:test:built": "node dist/server/src/smoke-test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.0.1",
    "@modelcontextprotocol/sdk": "1.24.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "esbuild": "0.25.5",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "@types/node": "24.3.0"
  }
}
