{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "types": [
      "node"
    ]
  },
  "include": [
    "server/src/**/*.ts",
    "web/src/**/*.tsx"
  ]
}
